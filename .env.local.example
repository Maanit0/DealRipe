ANTHROPIC_API_KEY=sk-ant-...
# Optional override; defaults to claude-sonnet-4-6
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Supabase. See SETUP.md for how to populate these.
# The anon key is safe to expose to the browser (RLS enforces access).
# The service role key bypasses RLS and must stay server-side only.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Rolldog CRM (Magaya pilot).
# Pending. The Rolldog client in lib/rolldog.ts throws RolldogPendingError
# until all three of these are populated AND the Swagger docs land
# (Jeff, June 9 call). Scope enforcement in lib/crm-scope.ts runs without
# these env vars.
ROLLDOG_BASE_URL=
ROLLDOG_CLIENT_ID=
ROLLDOG_CLIENT_SECRET=

# Email (Resend). Used by lib/mailer.ts for the post-call summary and the
# pre-call briefing delivery. RESEND_API_KEY is the workspace key; MAIL_FROM
# must be a verified sender on your Resend domain. Both required to send;
# rendering/previews work without them. Server-side only; never NEXT_PUBLIC_.
RESEND_API_KEY=
MAIL_FROM="DealRipe <notify@dealripe.com>"

# Recall.ai (region us-west-2).
# Workspace token used by lib/recall.ts as `Authorization: Token <key>`.
# Used by scripts/test-recall-bot.ts (live end-to-end proof) and by
# deleteSourceRecording() in lib/transcript-ingest.ts for the DPA
# delete-after-pull commitment. Server-side only; never NEXT_PUBLIC_.
RECALL_API_KEY=

# Microsoft OAuth (Magaya pilot, app id 853eae49-4e4e-4af0-8bee-04ef4fa62f64).
# Multi-tenant Azure app with delegated User.Read + Calendars.Read + offline_access.
# MICROSOFT_REDIRECT_URI lets dev override the production callback URL
# (set to http://localhost:3000/auth/microsoft/callback locally).
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=

# OAuth authority. Decides which Microsoft accounts can complete the flow:
#   organizations  -> Azure AD work/school accounts only. PRODUCTION DEFAULT.
#   common         -> Work/school AND personal Microsoft accounts. Use this
#                     for local dev testing when you only have a personal
#                     @outlook.com / @hotmail.com account.
#   <tenant-uuid>  -> A specific Azure AD tenant id; locks the flow to one
#                     customer org.
# Leaving this blank falls back to "organizations".
MICROSOFT_AUTHORITY=

# Refresh-token encryption (AES-256-GCM).
# Generate with: openssl rand -base64 32
# Rotating this key invalidates every stored refresh_token; users must
# reconnect via /auth/microsoft/connect.
TOKEN_ENCRYPTION_KEY=

# Cron auth (Vercel).
# Vercel automatically attaches `Authorization: Bearer ${CRON_SECRET}` to
# every cron invocation when this env var is set on the project. The
# /api/cron/* routes reject any request without the matching header.
# Generate with: openssl rand -base64 32
CRON_SECRET=

# Demo access gate (middleware.ts).
# /forecast and /demo are gated behind HTTP Basic Auth so the demo is not
# public. Set both in Vercel + .env.local. In production, if these are unset
# the gate fails closed (denies everyone). In local dev, unset = open.
DEMO_ACCESS_USER=
DEMO_ACCESS_PASSWORD=

# Supabase magic-link auth.
# The anon key + URL above are already used by the @supabase/ssr clients
# in lib/supabase-server.ts and lib/supabase-browser.ts. No new env vars
# are needed for the auth flow itself. The custom_access_token_hook in
# supabase/schema.sql must be enabled in the Supabase dashboard:
#   Authentication > Hooks > Custom Access Token Hook
#   -> public.custom_access_token_hook
# Then enable Email OTP (magic link) under Authentication > Providers.
# Set the Site URL to your deployment origin and add the callback
# (https://<origin>/auth/callback) under Redirect URLs.

# Salesforce read-only (Magaya pilot).
# Used by lib/salesforce.ts for outcome labeling — exactly three fields
# (StageName, IsClosed, IsWon) on three pilot opportunities. Read-only
# is a hard architectural line; there is no Salesforce write path.
# client_credentials OAuth; if Magaya's admin issues a different grant
# type, lib/salesforce.ts mintAccessToken() is the one function to swap.
SALESFORCE_INSTANCE_URL=
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
