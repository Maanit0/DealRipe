ANTHROPIC_API_KEY=sk-ant-...
# Optional override; defaults to claude-sonnet-4-6
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Supabase. See SETUP.md for how to populate these.
# The anon key is safe to expose to the browser (RLS enforces access).
# The service role key bypasses RLS and must stay server-side only.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
